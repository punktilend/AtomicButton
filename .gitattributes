# Normalize line endings to LF in the repo, check out as native on each OS
* text=auto

# Force LF for source files (keeps CI and cross-platform diffs clean)
*.cpp    text eol=lf
*.h      text eol=lf
*.cmake  text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.txt    text eol=lf

# Binaries
*.exe    binary
*.dll    binary
*.lib    binary
*.png    binary
*.jpg    binary
*.wav    binary
*.flac   binary
*.mp3    binary
